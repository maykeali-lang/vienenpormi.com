# ---- dependencias / build ----
web/node_modules/
web/dist/
*.local
.DS_Store
__pycache__/
*.pyc

# ---- entornos / secretos ----
.env
.env.*
!.env.example

# ---- config local de herramientas ----
.claude/
web/.claude/

# ---- datos de runtime (contador de plays, records, notas del buzón) ----
