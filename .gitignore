api/*.json
web/server/*.json

# ---- másters crudos (demasiado pesados para git; ~3 GB) ----
# el sitio corre solo con web/public/ ; esto son las fuentes de producción
web/audio_raw/
web/video intro/
web/orgullo master/
web/ira /
web/libreta game/
web/about band/
web/assets new/
web/cover album/
web/fanart/
